@startuml
skinparam backgroundColor #FFFFFF
skinparam rectangle {
  BackgroundColor #F1F5F9
  BackgroundColor<<ext>> #FDF3E7
  BackgroundColor<<gear>> #F8FAFC
  BackgroundColor<<fw>> #F8FAFC
  BackgroundColor<<l4>> #F8FAFC
  BorderColor #475569
  BorderColor<<ext>> #B7791F
  BorderColor<<gear>> #94A3B8
  BorderColor<<fw>> #8A6210
  BorderColor<<l4>> #1F6FD0
  FontColor #1B2635
}
skinparam package {
  BorderColor #94A3B8
  BackgroundColor transparent
  FontColor #475569
}
title Microservice Platform — 결제 처리 Process
' flowcast source: flowcast 합성 예제 (component)
package "< Internal >" {
  rectangle "API Gateway\n:8080" as gw
  rectangle "Order Service\n:8081" as order
  rectangle "Payment Service\n:8082" as pay
  rectangle "Order DB" as db
}
rectangle "Payment Gateway" as psp <<ext>>

gw --> order : 1. 주문 생성\n( http )
order --> db : 2. 주문 저장\n( jdbc )
gw --> pay : 3. 결제 요청\n( http )
pay --> psp : 4. 카드 승인\n( https )
@enduml

